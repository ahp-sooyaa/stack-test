# Supabase (shared across all environments)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional app origin (used for auth redirect URL fallback)
NEXT_PUBLIC_APP_URL=

# Optional alias if you prefer this name
SUPABASE_DB_URL=

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Example: https://pub-abc123.r2.dev or https://cdn.example.com
R2_PUBLIC_URL_BASE=
# MB
R2_MAX_UPLOAD_SIZE_MB=5
